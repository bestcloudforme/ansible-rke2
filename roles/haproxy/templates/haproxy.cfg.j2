# {{ ansible_managed }}
# HAProxy configuration for RKE2 HA cluster

global
    log         /dev/log local0
    log         /dev/log local1 notice
    chroot      /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user        haproxy
    group       haproxy
    daemon
    maxconn     {{ haproxy_maxconn }}

defaults
    mode                    tcp
    log                     global
    option                  tcplog
    option                  dontlognull
    retries                 3
    timeout queue           1m
    timeout connect         10s
    timeout client          1m
    timeout server          1m
    timeout check           10s
    default-server init-addr last,libc,none

#---------------------------------------------------------------------
# Stats page
#---------------------------------------------------------------------
listen stats
    bind {{ haproxy_stats_bind }}:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats admin if LOCALHOST
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

#---------------------------------------------------------------------
# Kubernetes API Server - port {{ haproxy_api_frontend_port }}
#---------------------------------------------------------------------
frontend k8s_api
    bind *:{{ haproxy_api_frontend_port }}
    mode tcp
    option tcplog
    default_backend k8s_api_backend

backend k8s_api_backend
    mode tcp
    option tcp-check
    balance {{ haproxy_balance_algorithm }}
{% for host in groups['masters'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:6443 check inter {{ haproxy_check_interval }} fall {{ haproxy_check_fall }} rise {{ haproxy_check_rise }}
{% endfor %}

#---------------------------------------------------------------------
# RKE2 Supervisor/Join API - port {{ haproxy_join_frontend_port }}
#---------------------------------------------------------------------
frontend rke2_join
    bind *:{{ haproxy_join_frontend_port }}
    mode tcp
    option tcplog
    default_backend rke2_join_backend

backend rke2_join_backend
    mode tcp
    option tcp-check
    balance {{ haproxy_balance_algorithm }}
{% for host in groups['masters'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:9345 check inter {{ haproxy_check_interval }} fall {{ haproxy_check_fall }} rise {{ haproxy_check_rise }}
{% endfor %}
