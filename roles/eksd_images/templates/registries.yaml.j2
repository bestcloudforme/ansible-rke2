# RKE2 private registry mirror configuration
# Generated by ansible-rke2
mirrors:
  "docker.io":
    endpoint:
      - "{{ rke2_registry_mirror }}"
  "{{ eksd_registry }}":
    endpoint:
      - "{{ rke2_registry_mirror }}"
{% if rke2_registry_mirror_tls_skip | default(false) | bool %}
configs:
  "{{ rke2_registry_mirror | regex_replace('^https?://', '') }}":
    tls:
      insecure_skip_verify: true
{% endif %}
