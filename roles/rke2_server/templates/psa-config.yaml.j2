{# Pod Security Admission Configuration for RKE2 #}
apiVersion: apiserver.config.k8s.io/v1
kind: AdmissionConfiguration
plugins:
  - name: PodSecurity
    configuration:
      apiVersion: pod-security.admission.config.k8s.io/v1
      kind: PodSecurityConfiguration
      defaults:
        enforce: "{{ rke2_pod_security_admission }}"
        enforce-version: "latest"
        audit: "{{ rke2_pod_security_admission }}"
        audit-version: "latest"
        warn: "{{ rke2_pod_security_admission }}"
        warn-version: "latest"
      exemptions:
        namespaces:
          - kube-system
          - kube-public
          - kube-node-lease
          - monitoring
          - logging
