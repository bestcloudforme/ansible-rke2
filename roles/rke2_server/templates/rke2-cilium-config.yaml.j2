{# Cilium HelmChartConfig for RKE2 #}
apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: rke2-cilium
  namespace: kube-system
spec:
  valuesContent: |-
{% if rke2_cilium_kube_proxy_replacement | default(true) | bool %}
    kubeProxyReplacement: true
    k8sServiceHost: {{ rke2_lb_vip if (rke2_lb_type in ['kube-vip', 'haproxy'] and rke2_lb_vip | default('') | length > 0) else (rke2_lb_external_host if rke2_lb_external_host | default('') | length > 0 else ansible_host) }}
    k8sServicePort: 6443
{% endif %}
{% if rke2_cilium_bpf_masquerade | default(true) | bool %}
    bpf:
      masquerade: true
{% endif %}
    operator:
      replicas: {{ 2 if (rke2_master_count | int > 1) else 1 }}
